    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "@types/node-fetch": "^2.6.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
