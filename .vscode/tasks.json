{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: build (root)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build"
		},
		{
			"label": "npm: test (root)",
			"type": "shell",
			"command": "npm",
			"args": [
				"test"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "test"
		},
		{
			"label": "npm: verify-tools",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"verify-tools"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "npm: startup-check",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"startup:check"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			}
		},
		{
			"label": "npm: build",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"options": {
				"cwd": "${workspaceFolder}/Terminal"
			},
			"group": "build"
		}
	]
}