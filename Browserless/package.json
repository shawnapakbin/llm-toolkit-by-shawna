{
  "name": "llm-toolkit-browserless",
  "version": "1.0.0",
  "private": true,
  "description": "Browserless.io integration for LM Studio Tools - browser automation with stealth, CAPTCHA solving, and anti-bot features",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js",
    "preflight": "tsx src/preflight-check.ts",
    "test": "jest",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@shared/types": "file:../shared",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  }
}
