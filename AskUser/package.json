{
  "name": "lm-studio-tools-ask-user",
  "version": "1.0.0",
  "private": true,
  "description": "Interactive ask-user interview tool for planning and clarification",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js",
    "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@shared/types": "file:../shared",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^22.13.1",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
