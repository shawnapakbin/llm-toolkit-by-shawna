{
  "name": "llm-toolkit-cli",
  "version": "1.0.0",
  "private": true,
  "description": "CLI interface for LLM Toolkit — run tools, workflows, and manage memory from the terminal",
  "main": "dist/index.js",
  "bin": {
    "llm": "dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest",
    "test:ci": "jest --ci"
  },
  "dependencies": {
    "@shared/types": "file:../shared",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "@types/node-fetch": "^2.6.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
