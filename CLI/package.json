{
  "name": "llm-toolkit-cli",
  "version": "1.0.0",
  "private": true,
  "description": "CLI interface for LLM Toolkit — run tools, workflows, and manage memory from the terminal",
  "main": "dist/index.js",
  "bin": {
    "llm": "dist/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "jest",
    "test:ci": "jest --ci",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@shared/types": "file:../shared",
    "better-sqlite3": "^12.6.2",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.11"
  }
}
