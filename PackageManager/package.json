{
  "name": "lm-studio-tools-package-manager",
  "version": "1.0.0",
  "description": "Multi-ecosystem package manager tool for Node.js, Python, Rust, Java, and Go",
  "main": "dist/PackageManager/src/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "dev:mcp": "ts-node src/mcp-server.ts",
    "start": "node dist/PackageManager/src/index.js",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "package-manager",
    "npm",
    "pip",
    "cargo",
    "maven",
    "gradle",
    "go",
    "multi-ecosystem"
