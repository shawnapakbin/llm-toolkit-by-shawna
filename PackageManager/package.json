{
  "name": "llm-toolkit-package-manager",
  "version": "2.1.0",
  "description": "Multi-ecosystem package manager tool for Node.js, Python, Rust, Java, and Go",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "dev:mcp": "ts-node src/mcp-server.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "package-manager",
    "npm",
    "pip",
    "cargo",
    "maven",
    "gradle",
    "go",
    "multi-ecosystem"
  ],
  "author": "Shawna Pakbin",
  "license": "LicenseRef-Shawna-NonCommercial",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@shared/types": "file:../shared",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "uuid": "^9.0.1",
    "zod": "^3.25.8"
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
