{
  "name": "lm-studio-tools-web-browser",
  "version": "2.1.0",
  "private": true,
  "description": "Full headless Chromium browser tool for LM Studio Tools (Playwright-powered)",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "build": "tsc -p tsconfig.json",
    "postinstall": "node scripts/postinstall.js",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@shared/types": "file:../shared",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "playwright": "^1.40.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.13.1",
    "@types/supertest": "^6.0.3",
    "fast-check": "^3.23.2",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
