{
  "name": "llm-toolkit-rag",
  "version": "1.0.0",
  "private": true,
  "description": "RAG MCP tool with ingestion, retrieval, and source lifecycle management",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js",
    "test": "jest"
  },
  "dependencies": {
    "@lmstudio/sdk": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@shared/types": "file:../shared",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  }
}
