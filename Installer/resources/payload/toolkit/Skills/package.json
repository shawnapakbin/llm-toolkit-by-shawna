{
  "name": "llm-toolkit-skills",
  "version": "2.1.0",
  "private": true,
  "description": "Skills MCP tool for managing and executing agent skills",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:mcp": "tsx src/mcp-server.ts",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js"
  },
  "dependencies": {
    "@lmstudio/sdk": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@shared/types": "file:../shared",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.13.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "fast-check": "^3.23.2",
    "supertest": "^7.1.1",
    "ts-jest": "^29.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
